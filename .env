APP_ENV=dev
PORT=3000
COOKIE_SECRET=gC3X6w6tec_fbE2YBq9FGA

# Admin felhasználó
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=superadmin_zsolika

# Adatbázis beállítások
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vendure
DB_USERNAME=need-it
DB_PASSWORD=zsolika
DB_SCHEMA=public



# Asset kezelés beállításai
# Plugin választó a VPS asset kezeléshez - értéke lehet "default" vagy "advanced"
# Ha "default", akkor nem használjuk a VPS asset kezelést
# Ha "advanced", akkor a VPS asset kezelést használjuk
USE_VPS_UPLOAD=advanced

# Asset URL prefix - csak akkor használjuk, ha USE_VPS_UPLOAD=advanced
# Ez az URL prefix lesz használva a frontend számára a képek megjelenítéséhez
ASSET_URL_PREFIX=https://assets.need-shit.fun/
# VPS Asset Sync Plugin beállítások - csak akkor használjuk, ha USE_VPS_UPLOAD=advanced
#VPS_UPLOAD_URL=http://localhost:3030/upload
VPS_UPLOAD_URL=http://assets.need-shit.fun:3000/upload
VPS_UPLOAD_TIMEOUT=10000

# Plugin választók - értékük lehet "default" vagy "advanced"
# Ha "default", akkor az egyszerűbb beépített plugineket használjuk
# Ha "advanced", akkor a fejlettebb külső plugineket használjuk
USE_JOB_QUEUE=default
USE_SEARCH=default

# Elasticsearch beállítások (csak ha USE_SEARCH=advanced)
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200

# Redis beállítások (csak ha USE_JOB_QUEUE=advanced)
REDIS_HOST=localhost
REDIS_PORT=6379
