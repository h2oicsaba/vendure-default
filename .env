# Vendure környezeti változók
APP_ENV=dev
PORT=3000
COOKIE_SECRET=gC3X6w6tec_fbE2YBq9FGA
PUBLIC_HOST_URL=https://admin.need-shit.fun
NODE_OPTIONS=--max_old_space_size=1024  


# Admin felhasználó
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=superadmin_zsolika

# Adatbázis beállítások
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vendure
DB_USERNAME=need-it
DB_PASSWORD=zsolika
DB_SCHEMA=public

# Asset kezelés beállításai
# Plugin választó az asset kezeléshez - értéke lehet "default" vagy "advanced"
# Ha "default", akkor a helyi asset kezelést használjuk
# Ha "advanced", akkor az S3/MinIO asset kezelést használjuk
USE_ASSET_STORAGE=advanced
# Ez az URL prefix lesz használva a frontend számára a képek megjelenítéséhez
ASSET_URL_PREFIX=https://minio.need-shit.fun/vendure-assets/
S3_BUCKET=vendure-assets
S3_ACCESS_KEY_ID=admin
S3_SECRET_ACCESS_KEY=YourSecurePassword123!
S3_ENDPOINT=https://minio.need-shit.fun
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true


# Plugin választók - értékük lehet "default" vagy "advanced"
# Ha "default", akkor az egyszerűbb beépített plugineket használjuk
# Ha "advanced", akkor a fejlettebb külső plugineket használjuk
USE_JOB_QUEUE=advanced
USE_SEARCH=default

# Worker beállítás - értéke lehet "true" vagy "false"
# Ha "true", akkor a rendszer worker szolgáltatást is használ
# Ha worker szolgáltatást használsz, akkor a USE_JOB_QUEUE=advanced beállítást kell használni mindenhol
USE_WORKER=true

# Elasticsearch beállítások (csak ha USE_SEARCH=advanced)
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200

# Redis beállítások (csak ha USE_JOB_QUEUE=advanced)
# Railway által biztosított környezeti változók:
# REDISHOST - A Redis szerver host neve
# REDISPORT - A Redis szerver portja
# REDISPASSWORD - A Redis szerver jelszó
# REDISUSER - A Redis felhasználónév (ha van)
# REDIS_URL - A teljes Redis kapcsolati URL

# Redis beállítások - Railway-ben ezeket automatikusan beállítja a rendszer
# De lokálisan teszthez szükséges lehet beállítani
REDISHOST=redis.need-shit.fun
REDISPORT=6379
# Ha van jelszó, akkor azt is be kell állítani
# REDISPASSWORD=your_password


USE_EMAIL=advanced
VERIFY_EMAIL_URL=http://localhost:8080/verify
PASSWORD_RESET_URL=http://localhost:8080/password-reset
CHANGE_EMAIL_URL=http://localhost:8080/verify-email-address-change

# SMTP beállítások - csak akkor szükségesek, ha USE_EMAIL=advanced

EMAIL_SMTP_HOST=smtp.forpsi.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=noreply@need-shit.fun
EMAIL_SMTP_PASS=Zsolika11-
EMAIL_SMTP_SECURE=false          
EMAIL_FROM_ADDRESS="\"Vendure Store\" <noreply@need-shit.fun>"

# Az AdminUiPlugin működéséhez szükséges
PUBLIC_HOST_URL=https://admin.need-shit.fun